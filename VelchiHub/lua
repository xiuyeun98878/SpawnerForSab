Title.Font = Enum.Font.GothamBold
Title.TextSize = 20
Title.TextColor3 = Color3.fromRGB(255,255,255)
Title.Parent = Frame

--// Button
local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0.8, 0, 0, 55)
Button.Position = UDim2.new(0.1, 0, 0.4, 0)
Button.Text = "Generate O.G Blocks"
Button.Font = Enum.Font.GothamBold
Button.TextSize = 18
Button.TextColor3 = Color3.fromRGB(255,255,255)
Button.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
Button.Parent = Frame

Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 10)

--// PROPER DRAG SYSTEM
local UIS = game:GetService("UserInputService")
local dragging = false
local dragStart, startPos

Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		Frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

--// BUTTON CLICK (CREATE TIMER ONLY AFTER CLICK)
Button.MouseButton1Click:Connect(function()

	-- prevent multiple timers
	if Frame:FindFirstChild("Timer") then return end

	local Timer = Instance.new("TextLabel")
	Timer.Name = "Timer"
	Timer.Size = UDim2.new(1, 0, 0, 30)
	Timer.Position = UDim2.new(0, 0, 0.75, 0)
	Timer.BackgroundTransparency = 1
	Timer.Font = Enum.Font.Gotham
	Timer.TextSize = 16
	Timer.TextColor3 = Color3.fromRGB(255,255,255)
	Timer.Parent = Frame

	for i = 30, 0, -1 do
		Timer.Text = "Generating... " .. i .. "s"
		task.wait(1)
	end

	Timer.Text = "Done!"
end)
